{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "docker:up": "docker compose up -d",
        "docker:down": "docker compose down",
        "start:all": "npm run docker:down && npm run docker:up && concurrently -k \"php artisan serve\" \"npm run dev\"",
        "build": "vite build",
        "dev": "vite"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@fortawesome/fontawesome-free": "^7.2.0",
        "pretty-checkbox": "^3.0.3"
    }
}
